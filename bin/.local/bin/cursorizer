#!/usr/bin/env bash
if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(find ~/dev/code /Users/kavinvalli/ -mindepth 1 -maxdepth 1 -type d | sed "s/\/\//\//g" | fzf --margin 5% --padding 5% --preview 'ls {}' --color=fg:#c0caf5,bg:#11121D,hl:#bb9af7 \
	--color=fg+:#c0caf5,bg+:#1a1b26,hl+:#7dcfff \
	--color=info:#7aa2f7,prompt:#7dcfff,pointer:#7dcfff \
	--color=marker:#9ece6a,spinner:#9ece6a,header:#9ece6a)
fi

if [[ -z $selected ]]; then
    exit 0
fi

cursor $selected
