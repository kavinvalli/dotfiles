#!/usr/bin/env bash
if [[ $# -eq 1 ]]; then
    selected=$1
else
  selected=$(find ~/dev/code /Users/kavinvalli/ -mindepth 1 -maxdepth 1 -type d | sed "s/\/\//\//g" | fzf --preview 'ls {}' --color=bg:#101010,bg+:#232323,fg:#A0A0A0,fg+:#FFFFFF,hl:#FFC799,hl+:#FFC799,pointer:#FFC799,prompt:#FFC799,info:#5C5C5C)
fi

if [[ -z $selected ]]; then
    exit 0
fi

cursor $selected
